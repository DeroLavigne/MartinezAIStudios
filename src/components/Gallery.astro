---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Item {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  items: Item[];
  min?: number;
  ratio?: string;
}

const { items, min = 220, ratio = '3 / 4' } = Astro.props;
---

<div class="gallery" style={`--min:${min}px; --ratio:${ratio};`}>
  {items.map((it, i) => (
    <figure class="gallery-item" data-reveal="zoom" style={`--reveal-delay:${(i % 4) * 0.08}s;`}>
      <div class="gallery-media">
        <Image
          src={it.src}
          alt={it.alt}
          widths={[300, 600, 900]}
          sizes="(max-width: 700px) 45vw, 300px"
          loading="lazy"
          data-zoom
        />
        <span class="gallery-glow" aria-hidden="true"></span>
      </div>
      {it.caption && <figcaption>{it.caption}</figcaption>}
    </figure>
  ))}
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(var(--min), 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .gallery-item {
    margin: 0;
    position: relative;
  }

  .gallery-media {
    position: relative;
    aspect-ratio: var(--ratio);
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-space);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.4s, box-shadow 0.4s;
  }

  .gallery-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-glow {
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, transparent 55%, rgba(176, 133, 255, 0.25));
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
  }

  .gallery-item:hover .gallery-media {
    transform: translateY(-5px);
    border-color: var(--accent-violet);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.5), 0 0 26px rgba(176, 133, 255, 0.28);
  }

  .gallery-item:hover .gallery-media img {
    transform: scale(1.08);
  }

  .gallery-item:hover .gallery-glow {
    opacity: 1;
  }

  .gallery-item figcaption {
    margin-top: 0.6rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    color: var(--accent-cyan);
    text-align: center;
  }
</style>
