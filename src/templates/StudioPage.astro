---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { Lang } from '../i18n/utils';
import { localizedPath } from '../i18n/utils';
import { t, getPageMeta } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const meta = getPageMeta('studio', lang);
const c = t(lang).studio;
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} currentPath="/studio">
  <div class="page-hero container">
    <h1>{meta.h1}</h1>
    <p class="lead">{c.intro}</p>
  </div>

  <section class="section">
    <div class="container">
      <h2>{c.philosophyTitle}</h2>
      <p>{c.philosophy}</p>
      <blockquote>
        <p>{c.quote}</p>
        <footer>{c.quoteAttr}</footer>
      </blockquote>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{c.texasTitle}</h2>
      <p>{c.texas}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{c.tableTitle}</h2>
      <table>
        <thead>
          <tr>{c.tableHeaders.map((h) => <th>{h}</th>)}</tr>
        </thead>
        <tbody>
          {c.tableRows.map((row) => (
            <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container epilogue">
      <h2>{c.epilogueTitle}</h2>
      {c.epilogue.map((line) => <p class="epilogue-line">{line}</p>)}
      <p><a href={localizedPath('/works', lang)} class="btn btn-primary">{lang === 'en' ? 'Explore Works' : 'Explorar Obras'}</a></p>
    </div>
  </section>
</BaseLayout>

<style>
  .epilogue-line {
    font-family: var(--font-display);
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    opacity: 0.9;
  }
</style>
