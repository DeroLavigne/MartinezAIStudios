<div class="glitch-intro" id="glitch-intro">
  <img src="/logo.png" alt="Martinez AI Studios" width="120" height="120" class="glitch-logo" />
  <div class="glitch-wordmark">
    <span class="wm-martinez">MARTINEZ</span>
    <span class="wm-studios">AI STUDIOS</span>
  </div>
</div>

<style>
  .glitch-intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #05040c;
    transition: opacity 0.5s ease, visibility 0.5s;
  }

  .glitch-intro.done {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .glitch-logo {
    animation: glitch-shake 0.8s steps(8) forwards;
  }

  .glitch-wordmark {
    margin-top: 1.5rem;
    text-align: center;
    animation: fade-settle 0.8s ease forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }

  .wm-martinez {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.35em;
    color: #fff;
  }

  .wm-studios {
    display: block;
    font-family: var(--font-display);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.25rem;
  }

  @keyframes glitch-shake {
    0%, 100% { transform: translate(0); filter: none; }
    10% { transform: translate(-3px, 2px); filter: hue-rotate(90deg) brightness(1.3); }
    20% { transform: translate(4px, -1px); filter: hue-rotate(-40deg); }
    30% { transform: translate(-2px, 3px); filter: contrast(1.4); }
    40% { transform: translate(3px, -2px); filter: hue-rotate(60deg); }
    50% { transform: translate(-4px, 1px); filter: brightness(1.2); }
    60% { transform: translate(2px, -3px); filter: none; }
    70% { transform: translate(-1px, 2px); filter: hue-rotate(20deg); }
    80% { transform: translate(1px, -1px); filter: none; }
    90% { transform: translate(0); filter: none; }
  }

  @keyframes fade-settle {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-intro {
      display: none;
    }
  }
</style>

<script>
  function runIntro() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const intro = document.getElementById('glitch-intro');
    if (!intro) return;
    if (sessionStorage.getItem('mas-intro-seen')) {
      intro.remove();
      return;
    }
    setTimeout(() => {
      intro.classList.add('done');
      sessionStorage.setItem('mas-intro-seen', '1');
      setTimeout(() => intro.remove(), 600);
    }, 900);
  }

  runIntro();
  document.addEventListener('astro:page-load', runIntro);
</script>
