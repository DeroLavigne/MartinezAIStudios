<div class="hero-logo-3d" id="hero-logo-3d">
  <img
    src="/logo-hero-transparent.png"
    alt="Martinez AI Studios"
    class="hero-logo-fallback"
    width="320"
    height="320"
  />
</div>

<style>
  .hero-logo-3d {
    position: relative;
    width: min(27rem, 46vh);
    height: min(27rem, 46vh);
    margin: 0 auto;
    z-index: 1;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  @media (max-width: 700px) {
    .hero-logo-3d {
      width: min(16rem, 82vw, 40vh);
      height: min(16rem, 82vw, 40vh);
    }
  }

  .hero-logo-3d canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    margin: 0 auto;
  }

  .hero-logo-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 0 32px rgba(176, 133, 255, 0.55))
      drop-shadow(0 0 64px rgba(94, 215, 255, 0.25));
    pointer-events: none;
  }

  .hero-logo-3d.is-ready .hero-logo-fallback {
    opacity: 0;
    visibility: hidden;
  }

  /* Smartphone: static logo, gentle float for life */
  .hero-logo-3d.is-static .hero-logo-fallback {
    animation: hero-logo-float 6s ease-in-out infinite;
  }

  @keyframes hero-logo-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo-3d.is-static .hero-logo-fallback {
      animation: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo-3d canvas {
      display: none !important;
    }

    .hero-logo-fallback {
      opacity: 1 !important;
      visibility: visible !important;
      position: relative;
    }
  }
</style>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

  interface LogoState {
    raf: number;
    renderer: THREE.WebGLRenderer;
    resizeObserver: ResizeObserver;
    scene: THREE.Scene;
  }

  const instances = new WeakMap<HTMLElement, LogoState>();
  const GLB_PATH = '/logo-martinez.glb';

  function disposeLogo(container: HTMLElement) {
    const state = instances.get(container);
    if (!state) return;
    cancelAnimationFrame(state.raf);
    state.resizeObserver.disconnect();
    state.scene.traverse((obj) => {
      if (obj instanceof THREE.Mesh) {
        obj.geometry?.dispose();
        const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
        mats.forEach((m) => m?.dispose());
      }
    });
    state.renderer.dispose();
    container.querySelector('canvas')?.remove();
    container.classList.remove('is-ready');
    instances.delete(container);
  }

  function enhanceMaterials(object: THREE.Object3D) {
    object.traverse((child) => {
      if (!(child instanceof THREE.Mesh)) return;
      const mats = Array.isArray(child.material) ? child.material : [child.material];
      for (const mat of mats) {
        if (!(mat instanceof THREE.MeshStandardMaterial)) continue;
        mat.metalness = Math.max(mat.metalness, 0.88);
        mat.roughness = Math.min(mat.roughness, 0.12);
        mat.emissive = new THREE.Color(0x9070cc);
        mat.emissiveIntensity = 0.18;
        mat.envMapIntensity = 1.2;
      }
    });
  }

  function fitModelToView(model: THREE.Object3D, targetSize = 2.05) {
    const box = new THREE.Box3().setFromObject(model, true);
    const size = box.getSize(new THREE.Vector3());
    const center = box.getCenter(new THREE.Vector3());
    const maxDim = Math.max(size.x, size.y, size.z);
    const scale = targetSize / maxDim;
    model.scale.setScalar(scale);
    model.position.sub(center.multiplyScalar(scale));
  }

  function isPhone() {
    const narrow = window.matchMedia('(max-width: 767px)').matches;
    const coarse = window.matchMedia('(pointer: coarse)').matches;
    const uaMobile = /Android|webOS|iPhone|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
    return narrow || (coarse && uaMobile);
  }

  function initHeroLogo() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // On smartphones, skip WebGL and keep the lightweight static logo (looks crisp,
    // loads fast, stays centered). The .hero-logo-fallback image remains visible.
    if (isPhone()) {
      document.getElementById('hero-logo-3d')?.classList.add('is-static');
      return;
    }

    const container = document.getElementById('hero-logo-3d');
    if (!container || instances.has(container)) return;

    startHeroLogo(container);
  }

  function startHeroLogo(container: HTMLElement) {
    disposeLogo(container);
    container.querySelectorAll('canvas').forEach((c) => c.remove());

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 100);
    camera.position.set(0, 0, 5.2);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    renderer.setClearColor(0x000000, 0);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.4;
    container.prepend(renderer.domElement);

    const logoGroup = new THREE.Group();
    scene.add(logoGroup);

    const keyLight = new THREE.DirectionalLight(0xffffff, 2.6);
    keyLight.position.set(3, 4, 6);
    scene.add(keyLight);

    const rimViolet = new THREE.DirectionalLight(0xb085ff, 2);
    rimViolet.position.set(-4, 1, 3);
    scene.add(rimViolet);

    const rimCyan = new THREE.DirectionalLight(0x5ed7ff, 1.4);
    rimCyan.position.set(4, -2, 2);
    scene.add(rimCyan);

    const goldFill = new THREE.PointLight(0xf8d878, 1.8, 14);
    goldFill.position.set(0, -1.5, 3);
    scene.add(goldFill);

    scene.add(new THREE.AmbientLight(0x1a1030, 0.5));

    // Calibrated transform (source of truth for both normal + calibration mode).
    const HERO_TRANSFORM = { rx: 0, ry: -3.142, rz: 0, px: -0.305, py: 0.38, pz: 0.15, scale: 1.11 };
    const CALIBRATE = new URLSearchParams(window.location.search).has('calibrate');
    logoGroup.rotation.set(HERO_TRANSFORM.rx, HERO_TRANSFORM.ry, HERO_TRANSFORM.rz);
    logoGroup.scale.setScalar(HERO_TRANSFORM.scale);

    const loader = new GLTFLoader();
    loader.load(
      GLB_PATH,
      (gltf) => {
        const model = gltf.scene;
        enhanceMaterials(model);
        fitModelToView(model);
        logoGroup.add(model);
        container.classList.add('is-ready');
      },
      undefined,
      (err) => console.error('GLB load failed:', err),
    );

    let raf = 0;
    let lastTime = performance.now();
    let spin = 0;
    const ROTATION_SPEED = 0.35; // rad/s — full turn ~18s

    function resize() {
      const w = container.clientWidth;
      const h = container.clientHeight;
      if (w === 0 || h === 0) return;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h, false);
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    }

    function animate(now: number) {
      const dt = Math.min((now - lastTime) / 1000, 0.05);
      lastTime = now;
      if (!CALIBRATE) spin += dt * ROTATION_SPEED;
      logoGroup.rotation.set(HERO_TRANSFORM.rx, HERO_TRANSFORM.ry + spin, HERO_TRANSFORM.rz);
      logoGroup.scale.setScalar(HERO_TRANSFORM.scale);
      logoGroup.position.set(HERO_TRANSFORM.px, HERO_TRANSFORM.py, HERO_TRANSFORM.pz);
      renderer.render(scene, camera);
      raf = requestAnimationFrame(animate);
    }

    resize();
    raf = requestAnimationFrame(animate);

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(container);
    instances.set(container, { raf, renderer, resizeObserver, scene });

    if (CALIBRATE) setupCalibrationUI(HERO_TRANSFORM);
  }

  function setupCalibrationUI(tf: Record<string, number>) {
    if (document.getElementById('glb-cal-panel')) return;

    // Grid + center guides overlay
    const overlay = document.createElement('div');
    overlay.id = 'glb-cal-grid';
    overlay.style.cssText =
      'position:fixed;inset:0;z-index:9996;pointer-events:none;' +
      'background-image:linear-gradient(rgba(176,133,255,0.10) 1px,transparent 1px),' +
      'linear-gradient(90deg,rgba(176,133,255,0.10) 1px,transparent 1px);' +
      'background-size:40px 40px;';
    const vLine = document.createElement('div');
    vLine.style.cssText = 'position:absolute;top:0;bottom:0;left:50%;width:1px;background:rgba(248,216,120,0.65);';
    const hLine = document.createElement('div');
    hLine.style.cssText = 'position:absolute;left:0;right:0;top:50%;height:1px;background:rgba(248,216,120,0.65);';
    overlay.append(vLine, hLine);
    document.body.appendChild(overlay);

    // Control panel
    const panel = document.createElement('div');
    panel.id = 'glb-cal-panel';
    panel.style.cssText =
      'position:fixed;top:80px;left:16px;z-index:9997;width:270px;padding:14px 16px;' +
      'background:rgba(12,7,24,0.92);backdrop-filter:blur(12px);border:1px solid rgba(176,133,255,0.3);' +
      'border-radius:8px;color:#fff;font:12px system-ui,sans-serif;';

    const fields: Array<[string, number, number, number]> = [
      ['rx', -3.1416, 3.1416, 0.01],
      ['ry', -3.1416, 3.1416, 0.01],
      ['rz', -3.1416, 3.1416, 0.01],
      ['px', -2, 2, 0.005],
      ['py', -2, 2, 0.005],
      ['pz', -2, 2, 0.005],
      ['scale', 0.4, 2.2, 0.01],
    ];
    const labels: Record<string, string> = {
      rx: 'Rot X', ry: 'Rot Y', rz: 'Rot Z', px: 'Pos X', py: 'Pos Y', pz: 'Pos Z', scale: 'Escala',
    };

    let rows = '<div style="font-weight:700;letter-spacing:0.06em;margin-bottom:8px;">GLB CALIBRATION</div>';
    for (const [k, min, max, step] of fields) {
      rows +=
        `<div style="display:grid;grid-template-columns:46px 1fr 56px;gap:6px;align-items:center;margin-bottom:6px;">` +
        `<span style="opacity:.8">${labels[k]}</span>` +
        `<input type="range" data-k="${k}" min="${min}" max="${max}" step="${step}" value="${tf[k]}" style="width:100%;accent-color:#b085ff">` +
        `<input type="number" data-n="${k}" step="${step}" value="${tf[k]}" style="width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(176,133,255,.3);color:#fff;border-radius:4px;padding:2px 4px;">` +
        `</div>`;
    }
    rows +=
      '<div style="display:flex;gap:6px;margin-top:8px;">' +
      '<button id="glb-cal-reset" style="flex:1;cursor:pointer;background:rgba(176,133,255,.15);border:1px solid rgba(176,133,255,.3);color:#fff;padding:6px;border-radius:5px;">Reset</button>' +
      '<button id="glb-cal-copy" style="flex:1;cursor:pointer;background:rgba(248,216,120,.16);border:1px solid rgba(248,216,120,.4);color:#fff;padding:6px;border-radius:5px;">Copiar JSON</button>' +
      '</div>' +
      '<div id="glb-cal-status" style="color:#f8d878;min-height:14px;margin-top:6px;"></div>' +
      '<textarea id="glb-cal-out" readonly style="width:100%;height:120px;margin-top:8px;background:rgba(0,0,0,.5);border:1px solid rgba(176,133,255,.3);color:#5ed7ff;border-radius:5px;padding:6px;font:11px monospace;"></textarea>';
    panel.innerHTML = rows;
    document.body.appendChild(panel);

    const defaults = { ...tf };
    const round = (v: number) => Math.round(v * 1000) / 1000;
    const out = panel.querySelector('#glb-cal-out') as HTMLTextAreaElement;

    function updateOut() {
      out.value = JSON.stringify(
        {
          rotation: { x: round(tf.rx), y: round(tf.ry), z: round(tf.rz) },
          position: { x: round(tf.px), y: round(tf.py), z: round(tf.pz) },
          scaleMultiplier: round(tf.scale),
          camera: { fov: 35, z: 5.2 },
        },
        null,
        2,
      );
    }
    function sync(k: string) {
      const r = panel.querySelector(`input[data-k="${k}"]`) as HTMLInputElement | null;
      const n = panel.querySelector(`input[data-n="${k}"]`) as HTMLInputElement | null;
      if (r) r.value = String(tf[k]);
      if (n) n.value = String(tf[k]);
    }

    panel.querySelectorAll('input[data-k]').forEach((el) => {
      el.addEventListener('input', () => {
        const input = el as HTMLInputElement;
        tf[input.dataset.k as string] = parseFloat(input.value);
        sync(input.dataset.k as string);
        updateOut();
      });
    });
    panel.querySelectorAll('input[data-n]').forEach((el) => {
      el.addEventListener('input', () => {
        const input = el as HTMLInputElement;
        const v = parseFloat(input.value);
        if (!Number.isNaN(v)) {
          tf[input.dataset.n as string] = v;
          sync(input.dataset.n as string);
          updateOut();
        }
      });
    });
    (panel.querySelector('#glb-cal-reset') as HTMLButtonElement).addEventListener('click', () => {
      Object.assign(tf, defaults);
      Object.keys(tf).forEach(sync);
      updateOut();
    });
    (panel.querySelector('#glb-cal-copy') as HTMLButtonElement).addEventListener('click', async () => {
      updateOut();
      const status = panel.querySelector('#glb-cal-status') as HTMLDivElement;
      try {
        await navigator.clipboard.writeText(out.value);
        status.textContent = 'JSON copiado.';
      } catch {
        status.textContent = 'Copialo manualmente del cuadro.';
      }
    });

    updateOut();
  }

  initHeroLogo();
  document.addEventListener('astro:page-load', initHeroLogo);
  document.addEventListener('astro:before-swap', () => {
    const container = document.getElementById('hero-logo-3d');
    if (container) disposeLogo(container);
  });
</script>
